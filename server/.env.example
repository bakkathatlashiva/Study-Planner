GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/study-planner
PORT=5000
ALLOWED_ORIGIN=https://your-app.vercel.app

# Valkey / Redis — get a free instance from Upstash (upstash.com) or Render
# Format: redis://:<password>@<host>:<port>  or  rediss://... for TLS
VALKEY_URL=redis://default:<password>@<host>:6379
